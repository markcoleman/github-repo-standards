# Repository standards configuration.
#
# Keep this file small and data-only so standards checks can run locally without
# package managers, runtimes, network access, or executable config evaluation.

REQUIRED_README_PATH="README.md"
MIN_README_BYTES="1"
REQUIRED_SECURITY_PATH="SECURITY.md"
REQUIRED_CONTRIBUTING_PATH="CONTRIBUTING.md"
REQUIRED_AGENT_GUIDE_PATH="agent.md"
REQUIRED_GITIGNORE_PATH=".gitignore"
